<?xml version="1.0" encoding="UTF-8"?>
<endpoints xmlns="http://java.sun.com/xml/ns/jax-ws/ri/runtime"
           version="2.0">

    <endpoint
            name="LanguageService"
            implementation="org.iti.soap.ws.LanguageWebService"
            url-pattern="/ws/language">
        <handler-chains xmlns="https://jakarta.ee/xml/ns/jakartaee">

            <handler-chain>
                <handler>
                    <handler-class>org.iti.soap.handler.SecurityHandler</handler-class>
                </handler>

            </handler-chain>

        </handler-chains>
    </endpoint>

    <endpoint
            name="FilmServices"
            implementation="org.iti.soap.ws.FilmWebService"
            url-pattern="/ws/film"/>

    <endpoint
            name="ActorServices"
            implementation="org.iti.soap.ws.ActorWebService"
            url-pattern="/ws/actor"/>

    <endpoint
            name="CountryServices"
            implementation="org.iti.soap.ws.CountryWebService"
            url-pattern="/ws/country"/>

    <endpoint
            name="CityServices"
            implementation="org.iti.soap.ws.CityWebService"
            url-pattern="/ws/city"/>

</endpoints>